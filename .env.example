# Copy this file to .env and fill in the real values.
# .env is gitignored — NEVER commit real credentials.

# --- Finnhub API ---
# Free key from https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# --- MongoDB (EC2-hosted) ---
# Format: mongodb://<user>:<password>@<ec2-public-ip>:27017/?authSource=admin
MONGO_URI=mongodb://username:password@ec2-ip-here:27017/?authSource=admin
MONGO_DB=stockdb
MONGO_COLLECTION=companies

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=eu-central-1
S3_BUCKET=se-data-with-ai-etl-project
# Prefix keeps your group's files tidy inside the shared bucket
S3_PREFIX=team-name/
